<?xml version="1.0" encoding="UTF-8"?>
<?import java.lang.String?>
<?import javafx.scene.chart.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.hotel.controller.ReportsController"
            styleClass="root-pane" prefWidth="1100" prefHeight="740">

    <top>
        <HBox styleClass="topbar" alignment="CENTER_LEFT" spacing="16">
            <Button text="← Back" onAction="#handleBack" styleClass="btn-back"/>
            <Label text="📊 Reports &amp; Analytics" styleClass="topbar-title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="🔄 Refresh" onAction="#handleRefresh" styleClass="btn-small"/>
        </HBox>
    </top>

    <center>
        <VBox spacing="16" styleClass="content-vbox">

            <!-- Stats row -->
            <HBox spacing="14">
                <VBox HBox.hgrow="ALWAYS">
                    <styleClass>
                        <String fx:value="stat-card"/>
                        <String fx:value="stat-purple"/>
                    </styleClass>
                    <Label text="Total Revenue" styleClass="stat-label"/>
                    <Label fx:id="totalRevenueLabel" text="₹0" styleClass="stat-value"/>
                </VBox>
                <VBox HBox.hgrow="ALWAYS">
                    <styleClass>
                        <String fx:value="stat-card"/>
                        <String fx:value="stat-blue"/>
                    </styleClass>
                    <Label text="Total Bookings" styleClass="stat-label"/>
                    <Label fx:id="totalBookingsLabel" text="0" styleClass="stat-value"/>
                </VBox>
                <VBox HBox.hgrow="ALWAYS">
                    <styleClass>
                        <String fx:value="stat-card"/>
                        <String fx:value="stat-green"/>
                    </styleClass>
                    <Label text="Active Bookings" styleClass="stat-label"/>
                    <Label fx:id="activeBookingsLabel" text="0" styleClass="stat-value"/>
                </VBox>
                <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
                    <Label text="Available / Total" styleClass="stat-label"/>
                    <Label fx:id="availableRoomsLabel" text="0/0" styleClass="stat-value"/>
                </VBox>
            </HBox>

            <!-- Tabbed view for Charts vs Data -->
            <TabPane VBox.vgrow="ALWAYS" tabClosingPolicy="UNAVAILABLE">
                
                <!-- Charts Tab -->
                <Tab text="📈 Charts &amp; Graphs">
                    <VBox spacing="12" styleClass="content-vbox">
                        <!-- Row 1: Status Distribution & Room Occupancy -->
                        <HBox spacing="14" VBox.vgrow="ALWAYS">
                            <VBox HBox.hgrow="ALWAYS" spacing="6">
                                <Label text="Booking Status Distribution" styleClass="form-title"/>
                                <PieChart fx:id="statusPieChart" VBox.vgrow="ALWAYS"/>
                            </VBox>
                            <VBox HBox.hgrow="ALWAYS" spacing="6">
                                <Label text="Room Type Occupancy" styleClass="form-title"/>
                                <BarChart fx:id="roomOccupancyChart" VBox.vgrow="ALWAYS"
                                         categoryGap="15">
                                    <xAxis>
                                        <CategoryAxis side="BOTTOM"/>
                                    </xAxis>
                                    <yAxis>
                                        <NumberAxis side="LEFT" label="Occupancy Count"/>
                                    </yAxis>
                                </BarChart>
                            </VBox>
                        </HBox>

                        <!-- Row 2: Revenue Trend -->
                        <VBox spacing="6" VBox.vgrow="ALWAYS">
                            <Label text="Revenue Trend (Last 7 Days)" styleClass="form-title"/>
                            <LineChart fx:id="revenueTrendChart" VBox.vgrow="ALWAYS">
                                <xAxis>
                                    <CategoryAxis side="BOTTOM" label="Date"/>
                                </xAxis>
                                <yAxis>
                                    <NumberAxis side="LEFT" label="Revenue (₹)"/>
                                </yAxis>
                            </LineChart>
                        </VBox>
                    </VBox>
                </Tab>

                <!-- Actions & Logs Tab -->
                <Tab text="🛠 Actions &amp; Logs">
                    <VBox spacing="12" styleClass="content-vbox" VBox.vgrow="ALWAYS">
                        <HBox spacing="10">
                            <Button text="📥 Export CSV" onAction="#handleExportCSV" styleClass="btn-secondary"/>
                            <Button text="📋 View Booking Logs" onAction="#handleViewLogs" styleClass="btn-outline"/>
                            <Button text="⚠ Error Logs" onAction="#handleViewErrorLogs" styleClass="btn-outline"/>
                            <Button text="💾 Backup (Serialization)" onAction="#handleBackup" styleClass="btn-thread"/>
                            <Button text="📂 Restore Info" onAction="#handleRestoreInfo" styleClass="btn-outline"/>
                        </HBox>

                        <VBox spacing="6" VBox.vgrow="ALWAYS">
                            <Label text="Log Viewer (Week 5 - File I/O)" styleClass="form-title"/>
                            <TextArea fx:id="logArea" VBox.vgrow="ALWAYS"
                                      editable="false" wrapText="true"
                                      styleClass="log-preview"
                                      promptText="Use the buttons above to view logs or backup info..."/>
                        </VBox>
                    </VBox>
                </Tab>

            </TabPane>

        </VBox>
    </center>
</BorderPane>
